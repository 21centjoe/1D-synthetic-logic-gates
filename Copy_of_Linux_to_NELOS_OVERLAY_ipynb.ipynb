    apt-get update > /dev/null 2>&1
    apt-get install -y fuse-overlayfs > /dev/null 2>&1
    echo "fuse-overlayfs installed."
fi

mkdir -p /tmp/lower /tmp/upper /tmp/work /tmp/merged
