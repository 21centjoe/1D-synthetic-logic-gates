        "bits_retrieved = [ebook_metrics['conceptual_bits_retrieved'], image_metrics['conceptual_bits_retrieved']]\n",
        "contiguous_reads = [ebook_metrics['conceptual_contiguous_reads'], image_metrics['conceptual_contiguous_reads']]\n",
